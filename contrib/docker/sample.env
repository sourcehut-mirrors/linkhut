# DB configuration
POSTGRES_DB=linkhut
POSTGRES_USER=linkhut
POSTGRES_PASSWORD=linkhut
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL="ecto://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# Generate random secret (e.g: `openssl rand -hex 32`)
SECRET_KEY_BASE="random_secret"
PORT="4000"
BIND_IP="public"
LINKHUT_HOST="example.com"

# Optional email configuration
# SMTP_HOST and EMAIL_FROM_ADDRESS are required to enable email delivery.
# When SMTP_HOST is not set, emails are only logged locally.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# EMAIL_FROM_NAME="linkhut"
# EMAIL_FROM_ADDRESS="noreply@example.com"
#
# SMTP authentication (optional, omit for unauthenticated SMTP)
# SMTP_USERNAME="your-email@example.com"
# SMTP_PASSWORD="your-password"
#
# TLS/SSL options (optional)
# SMTP_TLS: "if_available" (default), "always", or "never"
# SMTP_SSL: "true" for implicit SSL (port 465), default is "false"
# SMTP_TLS="if_available"
# SMTP_SSL="false"

# Optional IFTTT integration
# IFTTT_USER_ID="0"
# IFTTT_APPLICATION=""
# IFTTT_SERVICE_KEY=""

# Optional Prometheus monitoring
# PROMETHEUS_USERNAME=""
# PROMETHEUS_PASSWORD=""

# Optional archiving (page snapshots)
# ARCHIVING_MODE: "disabled" (default), "limited" (paying users), "enabled" (all users)
# ARCHIVING_DATA_DIR="/data/archives"
# ARCHIVING_SERVE_HOST="archive.example.com"
# ARCHIVING_MAX_FILE_SIZE="70000000"
# ARCHIVING_USER_AGENT_SUFFIX="+https://your-instance.com"
